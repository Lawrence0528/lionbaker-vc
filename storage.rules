rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 專案內嵌頁面可能以公開 URL 載入素材，需允許匿名讀取
    match /project_assets/{projectId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /agent_images/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
