rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 用戶資料（文件 ID 為 LINE userId；寫入與 Firebase Auth 並未綁定，故僅要求已登入）
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // 專案：避免公開讀取被爬取；公開預覽改走後端 renderSandbox（Admin SDK）輸出 HTML
    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    match /projects/{projectId}/form_responses/{responseId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 嵌入式 API 寫入走 Admin；用戶端可讀自身後台會用到的子集合文件
    match /projects/{projectId}/{collectionId}/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 漏斗健檢紀錄：以目前專案規則慣例（users/{userId} 的資料文件 ID 為 LINE userId）
    // 由於 Firebase Auth 與 LINE userId 未綁定，因此僅要求已登入即可建立健檢紀錄。
    match /users/{userId}/checkups/{checkupId} {
      allow create, update: if request.auth != null;
      allow read: if request.auth != null;
      allow delete: if false;
    }

    match /agents/{agentId} {
      allow read, write: if request.auth != null;
    }

    match /skills/{skillId} {
      allow read, write: if request.auth != null;
    }

    // 序號：一般用戶與超管皆需在已登入狀態下查詢／兌換／管理
    match /license_keys/{keyId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // 培訓班報名：表單送出未強制 Firebase 登入；報到頁僅單筆 get
    match /registrations_vibe/{regId} {
      allow get: if true;
      allow list: if false;
      allow create: if request.resource.data.status == 'pending'
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;
      allow update, delete: if false;
    }

    // 報名頁公開素材（影片 id、海報 URL）；僅授權管理員 Gmail 可寫入
    match /signup_page_settings/{docId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.token.email == 'charge0528@gmail.com';
      allow delete: if false;
    }

    // 其餘集合僅允許 Admin SDK（Cloud Functions 等）存取
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
